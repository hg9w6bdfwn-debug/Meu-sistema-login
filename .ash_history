import os
import platform
import sys
import time
# Banco de dados simulado
USUARIOS_CADASTRADOS = {
    "ios_user": "apple2026",
    "admin": "1234"
}
def limpar_tela():
    # Detecta o sistema e limpa a tela do terminal mobile
    if platform.system() == "Windows":
        os.system("cls")
    else:
        os.system("clear")
def executar_login_mobile():
    limpar_tela()
    print("=" * 30)
    print("    MOBILE iOS LOGIN CLI    ")
    print("=" * 30)
    
    tentativas = 3
    
    while tentativas > 0:
        usuario = input("Digite o Usuário: ").strip()
        
        # Como o getpass falha no iOS, usamos o input normal, 
        # mas limpamos a tela logo em seguida por segurança.
        senha = input("Digite a Senha: ").strip()
        
        # Limpa as credenciais da tela imediatamente após digitar
        limpar_tela()
        
        if usuario in USUARIOS_CADASTRADOS and USUARIOS_CADASTRADOS[usuario] == senha:
            print("\n[✓] Acesso Permitido!")
            print(f"Bem-vindo de volta, {usuario}.\n")
            return True
        else:
            tentativas -= 1
            print("\n[X] Credenciais incorretas.")
            if tentativas > 0:
                print(f"Você tem mais {tentativas} tentativa(s).\n")
                print("-" * 30)
            else:
                print("\n[Aviso] Muitas tentativas falhas. Encerrando...")
                time.sleep(2)
                sys.exit()
if __name__ == "__main__":
    executar_login_mobile()
    print("Carregando o painel de controle do iOS...")

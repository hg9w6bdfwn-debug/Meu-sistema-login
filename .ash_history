            padding: 12px 20px; border-bottom: 1px solid #f2f2f7;
            display: flex; justify-content: space-between; font-size: 14px;
        }
        .log-item:last-child { border-bottom: none; }
        .log-user { font-weight: 500; }
        .log-time { color: #8e8e93; }
        /* Modo Operador / Botões */
        .btn-action {
            display: block; width: 100%; padding: 14px; background-color: #ff3b30;
            color: white; border: none; border-radius: 12px; font-size: 16px;
            font-weight: 600; cursor: pointer; text-align: center; text-decoration: none;

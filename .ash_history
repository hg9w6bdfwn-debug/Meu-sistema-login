cat << 'EOF' > index.html
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Controle iOS</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, sans-serif; }
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); height: 100vh; display: flex; justify-content: center; align-items: center; padding: 20px; }
        .login-card { background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); width: 100%; max-width: 360px; text-align: center; }
        h2 { color: #333; margin-bottom: 5px; font-size: 24px; }
        .subtitle { color: #777; font-size: 14px; margin-bottom: 25px; }
        .input-group { margin-bottom: 15px; text-align: left; }
        label { display: block; color: #666; font-size: 14px; margin-bottom: 5px; font-weight: 500; }
        input { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 10px; font-size: 16px; outline: none; }
        button { width: 100%; padding: 14px; background: #764ba2; color: white; border: none; border-radius: 10px; font-size: 16px; font-weight: bold; cursor: pointer; margin-top: 10px; }
        .status-msg { margin-top: 15px; font-size: 14px; font-weight: 500; min-height: 20px; }
        .success { color: #2ecc71; }
        .error { color: #e74c3c; }
        .loading { color: #3498db; }
    </style>
</head>
<body>
    <div class="login-card">
        <h2>Painel de Controle iOS</h2>
        <p class="subtitle">Insira suas credenciais de acesso</p>
        <div class="input-group">
            <label>Usuário</label>
            <input type="text" id="usuario" placeholder="Digite seu usuário" autocomplete="off">
        </div>
        <div class="input-group">
            <label>Senha</label>
            <input type="password" id="senha" placeholder="Digite sua senha">
        </div>
        <button id="btnEntrar" onclick="executarLoginMobile()">Entrar</button>
        <div id="status" class="status-msg"></div>
    </div>
    <script>
        const USUARIOS_CADASTRADOS = { "ios_user": "apple2026", "admin": "1234" };
        let tentativas = 3;
        function executarLoginMobile() {
            const usuarioInput = document.getElementById("usuario").value.trim();
            const senhaInput = document.getElementById("senha").value.trim();
            const statusDiv = document.getElementById("status");
            if (tentativas <= 0) {
                statusDiv.className = "status-msg error";
                statusDiv.innerText = "Acesso bloqueado. Muitas tentativas falhas.";
                return;
            }
            statusDiv.className = "status-msg loading";
            statusDiv.innerText = "Carregando o painel de controle do iOS...";
            setTimeout(() => {
                if (USUARIOS_CADASTRADOS[usuarioInput] && USUARIOS_CADASTRADOS[usuarioInput] === senhaInput) {
                    statusDiv.className = "status-msg success";
                    statusDiv.innerText = "Login efetuado com sucesso! Redirecionando...";
                    setTimeout(() => { window.location.href = "painel.html"; }, 1000);
                } else {
                    tentativas--;
                    if (tentativas > 0) {
                        statusDiv.className = "status-msg error";
                        statusDiv.innerText = "Credenciais incorretas. Tentativas restantes: " + tentativas;
                    } else {
                        statusDiv.className = "status-msg error";
                        statusDiv.innerText = "Aviso: Muitas tentativas falhas. Encerrando...";
                        document.getElementById("btnEntrar").disabled = true;
                        document.getElementById("btnEntrar").style.background = "#999";
                    }
                }
            }, 500);
        }
    </script>
</body>
</html>
EOF
